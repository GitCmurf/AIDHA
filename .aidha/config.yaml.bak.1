config_version: 1
default_profile: default
env:
  dotenv_files:
    - .env
profiles:
  default:
    llm:
      model: gpt-5-mini
      api_key: ${AIDHA_OPENAI_API_KEY}
      reasoning_effort: medium
      verbosity: medium
    ytdlp:
      cookies_file: ./out/eval-matrix/youtube-cookies.txt
      remote_components: ejs:github
      js_runtimes: node
      timeout_ms: 120000
