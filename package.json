{
  "name": "aidha",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.5.0"
  },
  "license": "Apache-2.0",
  "pnpm": {
    "overrides": {
      "fast-uri": ">=3.1.2"
    }
  },
  "scripts": {
    "lint": "pnpm -r lint",
    "gen:types": "pnpm --filter @aidha/config gen:types",
    "test": "pnpm -r --if-present test:ci",
    "test:full": "pnpm -r --if-present test:full",
    "build": "pnpm -r build",
    "build:deps": "pnpm --filter @aidha/config --filter @aidha/graph-backend --filter @aidha/taxonomy build",
    "docs:serve": "./scripts/python -m mkdocs serve",
    "docs:catalog": "./scripts/python docs/_scripts/gen_catalog.py",
    "docs:linkcheck": "./scripts/python docs/_scripts/linkcheck.py",
    "docs:build": "./scripts/python docs/_scripts/gen_catalog.py && ./scripts/python docs/_scripts/validate_docs.py && ./scripts/python -m mkdocs build --strict"
  }
}
