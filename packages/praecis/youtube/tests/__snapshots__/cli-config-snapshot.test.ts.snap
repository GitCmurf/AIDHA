  model:
    from: gpt-4o-mini
    to: gpt-4o
activeSourceConfig:
  from:
    youtube:
      ytdlp:
        keep_files: true
"
`;

exports[`CLI Config Snapshots > config explain snapshot 1`] = `
"llm.model = "gpt-4o-mini" [core validated]
