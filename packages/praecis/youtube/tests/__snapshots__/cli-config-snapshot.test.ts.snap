`;

exports[`CLI Config Snapshots > config explain source snapshot 1`] = `
"activeSourceConfig.ytdlp.timeout_ms = 60000 [source validated]
  ↳ Source defaults (Tier 3) (from sources.youtube) — yt-dlp process timeout in milliseconds"
`;

exports[`CLI Config Snapshots > config list-profiles --json snapshot 1`] = `
"[
  "local",
  "prod"
]"
`;

