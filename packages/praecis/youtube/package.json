{
  "name": "@aidha/ingestion-youtube",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.3.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "aidha-youtube": "./dist/cli.js"
  },
  "author": "Colin Farmer (GitCmurf) (https://github.com/GitCmurf)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/GitCmurf/AIDHA.git"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:ci": "vitest run --silent --reporter=dot",
    "test:full": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "cli": "pnpm build && node dist/cli.js"
  },
  "dependencies": {
    "@aidha/config": "workspace:*",
    "@aidha/graph-backend": "workspace:*",
    "@aidha/taxonomy": "workspace:*",
    "compromise": "^14.15.0",
    "js-yaml": "^4.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
