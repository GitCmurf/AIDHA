# AIDHA Environment Configuration Template
# Copy this to .env or .env.local
# DO NOT COMMIT YOUR ACTUAL .env FILE

# ── LLM PROVIDER KEYS (Secrets Only) ──────────────────────────────────────────

# OpenAI
# Required for GPT-5-mini, GPT-5-nano, GPT-5.2
AIDHA_OPENAI_API_KEY=sk-...

# Google Gemini
# Required for Gemini 1.5 Flash, 1.5 Pro, 3.1 Pro
AIDHA_GOOGLE_API_KEY=...

# z.AI
AIDHA_ZAI_API_KEY=...

# Xiaomi AI
AIDHA_XIAOMI_API_KEY=...

# OpenRouter (Multi-provider aggregator)
AIDHA_OPENROUTER_API_KEY=...

# ── YOUTUBE INGESTION ─────────────────────────────────────────────────────────

# Optional: Unofficial InnerTube API key for faster transcript fetching
YOUTUBE_INNERTUBE_API_KEY=...

# Optional: Netscape-format cookies file for age-gated/private content
AIDHA_YTDLP_COOKIES_FILE=./cookies.txt
